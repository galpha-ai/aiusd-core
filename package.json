{
  "name": "aiusd-core",
  "version": "2.0.4",
  "description": "AIUSD Core — trading tools and account management for AI agents via MCP protocol.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "setup": "node scripts/skill-init.js",
    "postinstall": "node scripts/skill-init.js"
  },
  "bin": {
    "aiusd": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "SKILL.md",
    "skills/",
    "scripts/",
    "package.json",
    "tsconfig.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "commander": "^12.0.0",
    "ethers": "^6.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "agents": {
    "skills": [
      {
        "name": "aiusd-core",
        "path": "./"
      }
    ]
  },
  "keywords": [
    "agent-skill",
    "mcp",
    "aiusd",
    "trading",
    "skill",
    "typescript"
  ],
  "author": "AIUSD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/galpha-ai/aiusd-core.git"
  },
  "homepage": "https://github.com/galpha-ai/aiusd-core#readme",
  "bugs": {
    "url": "https://github.com/galpha-ai/aiusd-core/issues"
  }
}
